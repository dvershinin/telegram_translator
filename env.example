# Telegram API Credentials
# Get these from https://core.telegram.org/api
TTR_API_ID=your_api_id_here
TTR_API_HASH=your_api_hash_here

# OpenAI API Key (for translation)
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom configuration paths
# TTR_CONFIG_PATH=./config.yml
# TTR_CHANNELS_PATH=./channels.yml

# Optional: Logging level
# TTR_LOG_LEVEL=INFO

# Optional: Session storage directory
# TTR_SESSION_DIR=./data/sessions 